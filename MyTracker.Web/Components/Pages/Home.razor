@page "/"
@rendermode InteractiveServer
@using MyTracker.Domain.Configurations
@using MyTracker.Domain.Services
@inject StravaSettings Settings
@inject ActivityService ActivityService
@inject NavigationManager Nav

<PageTitle>MyTracker - Tableau de bord</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">🏃‍♂️ MyTracker</h1>
        <button class="btn btn-primary" @onclick="SyncFromStrava" disabled="@isSyncing">
            @(isSyncing ? "Synchronisation..." : "🔄 Actualiser Strava")
        </button>
    </div>

    <div class="mb-4">
        <span class="badge @(isConnected ? "bg-success" : "bg-warning")">
            @(isConnected ? "Connecté à Strava" : "Déconnecté de Strava")
        </span>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
            <span>⚠️ @errorMessage</span>
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (dashboard == null)
    {
        <p>Chargement...</p>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-6 col-md-3 mb-3">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <div class="fs-4 fw-bold">@dashboard.TotalActivities</div>
                        <div class="text-muted small">Séances en cache</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <div class="fs-4 fw-bold">@dashboard.TotalDistanceKm.ToString("F0") km</div>
                        <div class="text-muted small">Distance totale</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <div class="fs-4 fw-bold">@dashboard.DistanceLast7DaysKm.ToString("F0") km</div>
                        <div class="text-muted small">7 derniers jours</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <div class="fs-4 fw-bold">@dashboard.DistanceLast30DaysKm.ToString("F0") km</div>
                        <div class="text-muted small">30 derniers jours</div>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="mb-3">Dernière séance</h5>

        @if (dashboard.LatestActivity == null)
        {
            <div class="card shadow-sm">
                <div class="card-body text-center text-muted">
                    Aucune activité en cache. Cliquez sur "🔄 Actualiser Strava" pour synchroniser vos séances.
                </div>
            </div>
        }
        else
        {
            var latest = dashboard.LatestActivity;
            <div class="card shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h5 class="card-title mb-1">@SportEmoji(latest.Type) @latest.Name</h5>
                        <p class="card-text text-muted small mb-0">
                            📅 @latest.Date.ToShortDateString()
                            | 📏 @((latest.Distance / 1000).ToString("F2")) km
                            | ⏱️ @latest.FormattedDuration
                            @if (latest.AverageHeartRate.HasValue)
                            {
                                <text> | ❤️ @latest.AverageHeartRate.Value.ToString("F0") bpm</text>
                            }
                        </p>
                    </div>
                    <div>
                        @if (dashboard.LatestActivityIsDownloaded)
                        {
                            <button class="btn btn-success" @onclick='() => Nav.NavigateTo($"/visualizer/{latest.Id}")'>
                                📊 Analyser
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary" disabled="@isImportingLatest" @onclick="ImportLatest">
                                @(isImportingLatest ? "Import..." : "📥 Importer")
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="mt-4">
            <a href="/activities" class="btn btn-outline-secondary">Voir toutes les activités</a>
        </div>
    }
</div>

@code {
    private bool isConnected;
    private bool isSyncing;
    private bool isImportingLatest;
    private string? errorMessage;
    private ActivityService.HomeDashboardViewModel? dashboard;

    protected override async Task OnInitializedAsync()
    {
        isConnected = File.Exists("tokens.json") || !string.IsNullOrEmpty(Settings.RefreshToken);
        dashboard = await ActivityService.GetHomeDashboardAsync();
    }

    private async Task SyncFromStrava()
    {
        isSyncing = true;
        errorMessage = null;
        try
        {
            await ActivityService.SyncActivitiesListAsync();
            dashboard = await ActivityService.GetHomeDashboardAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Impossible de synchroniser avec Strava : {ex.Message}";
        }
        finally
        {
            isSyncing = false;
        }
    }

    private async Task ImportLatest()
    {
        if (dashboard?.LatestActivity == null) return;

        isImportingLatest = true;
        errorMessage = null;
        try
        {
            await ActivityService.GetActivityDataPointsAsync(dashboard.LatestActivity.Id);
            dashboard = await ActivityService.GetHomeDashboardAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Impossible d'importer cette activité : {ex.Message}";
        }
        finally
        {
            isImportingLatest = false;
        }
    }

    private static string SportEmoji(string type) => type switch
    {
        "Run" or "TrailRun" or "VirtualRun" => "🏃",
        "Ride" or "VirtualRide" or "EBikeRide" => "🚴",
        "Swim" => "🏊",
        "Walk" or "Hike" => "🚶",
        _ => "🏅"
    };
}
