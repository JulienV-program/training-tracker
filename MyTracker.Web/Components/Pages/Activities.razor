@page "/activities"
@rendermode InteractiveServer
@using MyTracker.Domain.Services
@inject ActivityService ActivityService
@inject NavigationManager Nav

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🏃‍♂️ Mes Activités</h1>
        <button class="btn btn-primary" @onclick="LoadActivities" disabled="@isLoading">
            @(isLoading ? "Synchronisation..." : "🔄 Actualiser Strava")
        </button>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
            <span>⚠️ @errorMessage</span>
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (activities == null)
    {
        <div class="text-center py-5">
            <p>Chargement...</p>
        </div>
    }
    else if (activities.Count == 0)
    {
        <div class="text-center py-5">
            <p>Aucune activité en cache. Cliquez sur "Actualiser" pour récupérer vos séances depuis Strava.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var act in activities)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card shadow-sm @(act.IsDownloaded ? "border-success" : "")">
                        <div class="card-body">
                            <h5 class="card-title text-truncate">@act.Name</h5>
                            <p class="card-text text-muted small">
                                📅 @act.Date.ToShortDateString() | 📏 @((act.Distance / 1000).ToString("F2")) km
                            </p>
                            
                            <div class="d-flex gap-2">
                                @if (act.IsDownloaded)
                                {
                                    <button class="btn btn-success w-100" @onclick='() => Nav.NavigateTo($"/visualizer/{act.Id}")'>
                                        📊 Analyser
                                    </button>
                                    <button class="btn btn-outline-secondary" title="Réimporter" disabled="@isLoading" @onclick="() => ReimportActivity(act.Id)">
                                        🔄
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-primary w-100" @onclick="() => DownloadAndRefresh(act.Id)">
                                        📥 Importer
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ActivityService.ActivityViewModel>? activities;
    private bool isLoading = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        // Lecture depuis le cache local SQLite, aucun appel Strava ici
        activities = await ActivityService.GetActivitiesDashboardAsync();
    }

    private async Task RefreshFromCache()
        => activities = await ActivityService.GetActivitiesDashboardAsync();

    private async Task LoadActivities()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            await ActivityService.SyncActivitiesListAsync(); // Appel Strava, fusionne dans le cache local
            await RefreshFromCache();
        }
        catch (Exception ex)
        {
            errorMessage = $"Impossible de synchroniser avec Strava : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DownloadAndRefresh(string id)
    {
        errorMessage = null;
        try
        {
            await ActivityService.GetActivityCsvAsync(id); // Télécharge et stocke sur le Mac
            await RefreshFromCache(); // Rafraîchit l'UI depuis le cache, pas de nouvel appel Strava
        }
        catch (Exception ex)
        {
            errorMessage = $"Impossible d'importer cette activité : {ex.Message}";
        }
    }

    private async Task ReimportActivity(string id)
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            await ActivityService.GetActivityDataPointsAsync(id, forceReimport: true);
            await RefreshFromCache();
        }
        catch (Exception ex)
        {
            errorMessage = $"Impossible de réimporter cette activité : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}